@model IEnumerable<KovacsWebshop.Models.Product>

<h2>Termekkezeles</h2>

<p>
    <a href="/Product/Create" class="btn btn-success">Uj termek</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nev</th>
            <th>Ar</th>
            <th>Tipus</th>
            <th>Muveletek</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProductId</td>
                <td>@item.Name</td>
                <td>@item.Price.ToString("c")</td>
                <td>@item.Type</td>
                <td>
                    <a href="/Product/Edit/@item.ProductId" class="btn btn-sm btn-warning">Szerkesztes</a>

                    <form action="/Product/Delete/@item.ProductId" method="post" style="display:inline">
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Biztosan torlod a termeket?')">Torles</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<a href="/Home/Index" class="btn btn-secondary">Vissza a fooldalra</a>